<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>Panel Administrador | AuthApp</title>
</head>
<body class="app-page">
    <%- include('partials/navbar') %>

    <main>
        <div class="container" style="margin-top: 30px; margin-bottom: 30px;">
            <div class="row">
                <div class="col s12">
                    <h4 class="page-title"><i class="material-icons">admin_panel_settings</i> Panel de Administrador</h4>
                </div>
            </div>

            <div class="row">
                <div class="col s12 m4">
                    <div class="card z-depth-2 stat-card stat-users">
                        <div class="card-content center-align white-text">
                            <i class="material-icons" style="font-size: 48px;">group</i>
                            <h3 id="stat-total" class="stat-number">0</h3>
                            <p>Total Usuarios</p>
                        </div>
                    </div>
                </div>
                <div class="col s12 m4">
                    <div class="card z-depth-2 stat-card stat-admins">
                        <div class="card-content center-align white-text">
                            <i class="material-icons" style="font-size: 48px;">verified_user</i>
                            <h3 id="stat-admins" class="stat-number">0</h3>
                            <p>Administradores</p>
                        </div>
                    </div>
                </div>
                <div class="col s12 m4">
                    <div class="card z-depth-2 stat-card stat-regular">
                        <div class="card-content center-align white-text">
                            <i class="material-icons" style="font-size: 48px;">person</i>
                            <h3 id="stat-users" class="stat-number">0</h3>
                            <p>Usuarios Regulares</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col s12">
                    <div class="card z-depth-3">
                        <div class="card-content">
                            <span class="card-title"><i class="material-icons">list</i> Lista de Usuarios</span>
                            <div class="table-responsive">
                                <table class="striped highlight responsive-table" id="users-table">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Nombre</th>
                                            <th>Email</th>
                                            <th>Teléfono</th>
                                            <th>Roles</th>
                                            <th>Registrado</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody id="users-tbody">
                                        <!-- Se llena con JS -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Modal para ver detalle de usuario -->
    <div id="user-detail-modal" class="modal modal-fixed-footer">
        <div class="modal-content">
            <h4><i class="material-icons">person</i> Detalle del Usuario</h4>
            <div class="divider" style="margin-bottom: 16px;"></div>
            <div class="row" id="modal-body">
                <!-- Se llena con JS -->
            </div>
        </div>
        <div class="modal-footer">
            <a href="#!" class="modal-close waves-effect waves-green btn-flat">Cerrar</a>
        </div>
    </div>

    <%- include('partials/scripts') %>
    <script src="/js/admin.js"></script>
</body>
</html>
