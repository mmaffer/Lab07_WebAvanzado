<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>Mi Perfil | AuthApp</title>
</head>
<body class="app-page">
    <%- include('partials/navbar') %>

    <main>
        <div class="container" style="margin-top: 30px; margin-bottom: 30px;">
            <div class="row">
                <div class="col s12">
                    <h4 class="page-title"><i class="material-icons">account_box</i> Mi Perfil</h4>
                </div>
            </div>
            <div class="row">
                <!-- Tarjeta de info -->
                <div class="col s12 m4">
                    <div class="card profile-card z-depth-3">
                        <div class="card-content center-align">
                            <div class="profile-avatar">
                                <img id="profile-img" src="" alt="Avatar" class="circle responsive-img">
                            </div>
                            <h5 id="profile-fullname" class="profile-name"></h5>
                            <p id="profile-email" class="grey-text"></p>
                            <div id="profile-roles" style="margin-top: 12px;"></div>
                            <div class="divider" style="margin: 16px 0;"></div>
                            <p><i class="material-icons tiny">cake</i> Edad: <strong id="profile-age"></strong> años</p>
                            <p><i class="material-icons tiny">date_range</i> Miembro desde: <strong id="profile-since"></strong></p>
                        </div>
                    </div>
                </div>
                <!-- Formulario de edición -->
                <div class="col s12 m8">
                    <div class="card z-depth-3">
                        <div class="card-content">
                            <span class="card-title"><i class="material-icons">edit</i> Editar Datos</span>

                            <form id="profileForm">
                                <div class="row">
                                    <div class="input-field col s12 m6">
                                        <i class="material-icons prefix">person</i>
                                        <input id="edit-name" type="text" required>
                                        <label for="edit-name">Nombre</label>
                                    </div>
                                    <div class="input-field col s12 m6">
                                        <i class="material-icons prefix">person_outline</i>
                                        <input id="edit-lastName" type="text" required>
                                        <label for="edit-lastName">Apellido</label>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="input-field col s12 m6">
                                        <i class="material-icons prefix">phone</i>
                                        <input id="edit-phone" type="text" required>
                                        <label for="edit-phone">Teléfono</label>
                                    </div>
                                    <div class="input-field col s12 m6">
                                        <i class="material-icons prefix">cake</i>
                                        <input id="edit-birthdate" type="text" class="datepicker" required>
                                        <label for="edit-birthdate">Fecha de Nacimiento</label>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="input-field col s12 m6">
                                        <i class="material-icons prefix">link</i>
                                        <input id="edit-url" type="text">
                                        <label for="edit-url">URL de Perfil</label>
                                    </div>
                                    <div class="input-field col s12 m6">
                                        <i class="material-icons prefix">home</i>
                                        <input id="edit-address" type="text">
                                        <label for="edit-address">Dirección</label>
                                    </div>
                                </div>

                                <div id="edit-msg" class="center-align" style="min-height: 24px; margin-bottom: 8px;"></div>

                                <div class="center-align">
                                    <button class="btn btn-large waves-effect waves-light btn-gradient" type="submit" id="btn-save">
                                        Guardar Cambios
                                        <i class="material-icons right">save</i>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/scripts') %>
    <script src="/js/profile.js"></script>
</body>
</html>
