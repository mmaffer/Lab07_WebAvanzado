<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>404 - Página No Encontrada | AuthApp</title>
</head>
<body class="error-page">
    <%- include('partials/navbar') %>

    <main>
        <div class="container">
            <div class="row valign-wrapper" style="min-height: 80vh;">
                <div class="col s12 center-align">
                    <div class="error-content">
                        <i class="material-icons error-icon" style="color: #f39c12;">explore_off</i>
                        <h1 class="error-code">404</h1>
                        <h4 class="error-title">Página No Encontrada</h4>
                        <p class="grey-text text-darken-1" style="font-size: 1.2rem; max-width: 500px; margin: 0 auto;">
                            La página que buscas no existe o ha sido movida.
                        </p>
                        <div style="margin-top: 30px;">
                            <a href="/" class="btn btn-large waves-effect waves-light btn-gradient">
                                <i class="material-icons left">home</i> Ir al Inicio
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/scripts') %>
</body>
</html>
