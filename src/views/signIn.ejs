<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>Iniciar Sesión | AuthApp</title>
</head>
<body class="auth-page">
    <%- include('partials/navbar') %>

    <main>
        <div class="container">
            <div class="row valign-wrapper" style="min-height: 80vh;">
                <div class="col s12 m8 offset-m2 l6 offset-l3">
                    <div class="card auth-card z-depth-4">
                        <div class="card-content">
                            <div class="center-align">
                                <i class="material-icons auth-icon">account_circle</i>
                                <h4 class="auth-title">Iniciar Sesión</h4>
                                <p class="grey-text text-darken-1">Ingresa tus credenciales para continuar</p>
                            </div>

                            <form id="signInForm" class="auth-form">
                                <div class="input-field">
                                    <i class="material-icons prefix">email</i>
                                    <input id="email" type="email" class="validate" required>
                                    <label for="email">Email</label>
                                </div>
                                <div class="input-field">
                                    <i class="material-icons prefix">lock</i>
                                    <input id="password" type="password" class="validate" required>
                                    <label for="password">Contraseña</label>
                                </div>

                                <div id="error-msg" class="red-text center-align" style="min-height: 24px; margin-bottom: 8px;"></div>

                                <button class="btn btn-large waves-effect waves-light btn-gradient full-width" type="submit" id="btn-signin">
                                    Ingresar
                                    <i class="material-icons right">send</i>
                                </button>
                            </form>

                            <div class="center-align" style="margin-top: 24px;">
                                <p>¿No tienes cuenta? <a href="/signUp" class="link-accent">Regístrate aquí</a></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/scripts') %>
    <script src="/js/signIn.js"></script>
</body>
</html>
